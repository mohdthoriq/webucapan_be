model File {
  id          String   @id @default(uuid()) @db.Uuid
  file_name   String?  @db.VarChar(255)
  file_url    String
  file_type   String?  @db.VarChar(50)
  mime_type   String?  @db.VarChar(100)
  file_size   BigInt?
  storage_path String?

  photoLinks             GreetingPhoto[]
  uploadedMusicGreetings Greeting[]      @relation("UploadedMusic")
  thumbnailGreetings     Greeting[]      @relation("Thumbnail")

  created_at DateTime @default(now())

  @@map("files")
}